---
import Layout from '../layouts/Layout.astro';

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const normalizedPath = path.replace(/^\//, '');
  return `${base}/${normalizedPath}`;
};
---

<Layout
  title="Nature & Nurture: Southern Maryland"
  description="Nature & Nurture: Southern Maryland is a Spirituality in Nature Group (SING) located in Calvert County, MD.  A peninsula of land where the Patuxent River joins the Chesapeake Bay."
>
  <header class="site-header">
    <div class="container nav-wrap">
      <div class="brand">
        <img
          class="brand-logo"
          src={withBase('/images/NatureNurtureLogo_imageonly_v4.png')}
          alt="Nature & Nurture: Southern Maryland logo"
          loading="eager"
          decoding="async"
        />
        <div>
          <p class="eyebrow">Nature & Nurture: Southern Maryland</p>
          <p class="tagline">A Spirituality in Nature Group (SING)</p>
        </div>
      </div>
      <nav aria-label="Primary navigation">
        <ul class="nav-list">
          <li><a href="#welcome">Welcome</a></li>
            <li><a href="#about">About</a></li>
          <li><a href="#about-place">Our Shared Place</a></li>
          <li><a href="#gatherings">Gatherings</a></li>
          <li><a href="#connect">Connect</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <section id="welcome" class="section hero">
      <div class="container">
        <article class="surface hero-card hero-inline">
          <h1>Welcome to Nature & Nurture: Southern Maryland</h1>
          <p>
            We gather to reconnect with the sacred through sky, shoreline, forest, and one another —
            honoring wonder, reflection, and belonging in the natural world.
          </p>
          <figure class="hero-image">
            <img
              src={withBase('/images/naturemandala.jpg')}
              alt="Nature mandala arranged with flowers, leaves, and natural materials"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </article>
      </div>
    </section>

    <section id="about" class="section">
      <div class="container">
        <h2>About Nature &amp; Nurture: Southern Maryland</h2>
        <article class="surface card about-card">
          <p>
            Nature &amp; Nurture: Southern Maryland is a welcoming Spirituality in Nature Group where people gather to
            slow down, notice the land, and share time in community. Our circle is rooted in a sense
            of reverence for the earth, curiosity about place, and simple practices that help us pay
            attention together.
          </p>
          <p>
            This space is ready for your fuller about copy when you have it. You can use it to share
            your mission, who the group is for, how gatherings work, or any details you want new
            visitors to understand first.
          </p>
        </article>
      </div>
    </section>

    <section id="about-place" class="section">
      <div class="container">
        <h2>Southern Maryland: Our Shared Place</h2>
        <div class="place-grid">
          <article class="surface card">
            <h3>Watershed & Geography</h3>
            <p>
              Our community sits where the Patuxent River meets the greater Chesapeake Bay watershed,
              near Lusby and the dramatic Calvert Cliffs. These Miocene-era formations hold millions of
              years of coastal history in layered sands, clays, and marine fossils.
            </p>
            <figure class="place-image">
              <img
                src={withBase('/images/watershed-geography.webp')}
                alt="Illustration of river channels flowing to the Chesapeake Bay near coastal cliffs"
                loading="lazy"
                decoding="async"
              />
            </figure>
          </article>
          <article class="surface card">
            <h3>Ecology</h3>
            <p>
              Coastal oak-pine forests, mountain laurel, and marsh edges shape this landscape. Bald
              eagles soar above creeks and coves, while fish, crabs, and other marine life sustain the
              estuary’s living web.
            </p>
            <figure class="place-image">
              <img
                src={withBase('/images/ecology.webp')}
                alt="Illustration of coastal forest and estuary wildlife habitat"
                loading="lazy"
                decoding="async"
              />
            </figure>
          </article>
          <article class="surface card">
            <h3>Indigenous Heritage</h3>
            <p>
              Placeholder for honoring the original peoples of this land, including the Piscataway Conoy
              and related Chesapeake region lineages, while acknowledging and uplifting existing tribal
              communities today.
            </p>
            <figure class="place-image">
              <img
                src={withBase('/images/indigenous-heritage.webp')}
                alt="Symbolic landscape illustration honoring Indigenous presence and relationship with land"
                loading="lazy"
                decoding="async"
              />
            </figure>
          </article>
        </div>
      </div>
    </section>

    <section id="gatherings" class="section gatherings">
      <div class="container">
        <h2>Gatherings & Calendar</h2>
        <article class="surface card gathering-details">
          <h3>Our Gatherings</h3>
          <p>
            Our gatherings open with a warm welcome and a calling of the Seven Directions, grounding us
            in a sacred circle where we reflect on the day&apos;s theme and learn about the local history and
            ecology of the land. After a centering practice and an inspirational reading, we transition
            into a blend of quiet solo time and a shared community activity designed to deepen our bond
            with the earth. We conclude each gathering by inviting personal reflections on our experiences
            and closing with shared gratitude for ourselves, one another, and the natural world.
          </p>
          <figure class="gathering-image">
            <img
              src={withBase('/images/sing_nature_mandala.webp')}
              alt="Nature mandala arranged with flowers, leaves, and natural materials"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </article>
        <div class="surface iframe-card">
          <p>Upcoming gatherings are listed below in agenda view.</p>
          <iframe
            class="calendar-embed"
            title="Nature & Nurture: Southern Maryland Gatherings Calendar"
            src="https://calendar.google.com/calendar/embed?src=748db8a7c2883d804e9257ebc7c994a01aee3781f451a68ab43d385228ac918d%40group.calendar.google.com&ctz=America%2FNew_York&mode=AGENDA&showTitle=0&showPrint=0&showTabs=0&showCalendars=0&showTz=0"
            loading="lazy"
            referrerpolicy="no-referrer"
            frameborder="0"
            scrolling="no"
            style="border: 0"
          ></iframe>
        </div>
      </div>
    </section>

    <section id="connect" class="section">
      <div class="container">
        <h2>Connect With Us</h2>
        <div class="forms-grid">
          <article class="surface card">
            <h3>Send Us a Message</h3>
            <form id="contact-form" novalidate>
              <p class="form-note">All fields are required.</p>

              <label for="name">Name *</label>
              <input id="name" name="name" type="text" required />

              <label for="email">Email *</label>
              <input id="email" name="email" type="email" required />

              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="5" required></textarea>

              <button class="button" type="submit">Send Message</button>
              <p id="form-status" role="status" aria-live="polite"></p>
            </form>
          </article>

          <article class="surface card">
            <h3>Newsletter Sign-up</h3>
            <form class="newsletter-form" action="#" method="post">
              <p class="form-note">Required fields are marked with *</p>

              <label for="newsletter-first-name">First Name *</label>
              <input
                id="newsletter-first-name"
                name="newsletter-first-name"
                type="text"
                required
                autocomplete="given-name"
              />

              <label for="newsletter-last-name">Last Name *</label>
              <input
                id="newsletter-last-name"
                name="newsletter-last-name"
                type="text"
                required
                autocomplete="family-name"
              />

              <label for="newsletter-email">Email Address *</label>
              <input
                id="newsletter-email"
                name="newsletter-email"
                type="email"
                required
                autocomplete="email"
              />

              <label for="newsletter-phone">Phone Number</label>
              <input id="newsletter-phone" name="newsletter-phone" type="tel" autocomplete="tel" />

              <button class="button newsletter-button" type="submit">Subscribe</button>
            </form>
          </article>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-wrap">
      <p>© {new Date().getFullYear()} Nature & Nurture: Southern Maryland.</p>
      <p>
        A
        {' '}
        <a
          href="https://www.centerforspiritualityinnature.org/spirituality-in-nature-groups"
          target="_blank"
          rel="noopener noreferrer"
        >
          Spirituality in Nature Group (SING)
        </a>
        {' '}in Southern Maryland.
      </p>
    </div>
  </footer>

  <script>
    const form = document.querySelector('#contact-form');
    const status = document.querySelector('#form-status');

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener('submit', (event) => {
        event.preventDefault();

        if (!form.checkValidity()) {
          status.textContent = 'Please complete all required fields before sending.';
          status.dataset.state = 'error';
          form.reportValidity();
          return;
        }

        const button = form.querySelector('button[type="submit"]');
        if (button instanceof HTMLButtonElement) {
          button.disabled = true;
          button.textContent = 'Sending...';
        }

        status.textContent = 'Thanks for reaching out. Your message is ready to be sent.';
        status.dataset.state = 'success';

        window.setTimeout(() => {
          if (button instanceof HTMLButtonElement) {
            button.disabled = false;
            button.textContent = 'Send Message';
          }
        }, 700);
      });
    }
  </script>
</Layout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 2;
    backdrop-filter: blur(6px);
    background: color-mix(in oklab, var(--color-bg-alt) 82%, white);
    border-bottom: 1px solid color-mix(in oklab, var(--color-primary) 18%, white);
  }

  .nav-wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0 0.4rem;
    flex-wrap: wrap;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand-logo {
    width: clamp(68px, 10vw, 104px);
    height: auto;
    display: block;
  }

  .eyebrow {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .tagline {
    margin: 0.2rem 0 0;
    color: color-mix(in oklab, var(--color-text) 80%, var(--color-primary));
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .nav-list a {
    text-decoration: none;
    font-weight: 500;
    padding: 0.3rem 0.55rem;
    border-radius: 0.35rem;
  }

  .nav-list a:hover,
  .nav-list a:focus-visible {
    background: color-mix(in oklab, var(--color-accent) 42%, white);
  }

  .hero-card {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    border-left: 6px solid var(--color-accent);
  }

  .section {
    scroll-margin-top: 4.5rem;
  }

  .hero-image {
    margin: 1rem 0 0;
  }

  .hero-image img {
    display: block;
    width: 100%;
    height: clamp(210px, 27vw, 285px);
    object-fit: cover;
    object-position: center 35%;
    border-radius: 0.65rem;
    border: 1px solid color-mix(in oklab, var(--color-primary) 18%, white);
    background: color-mix(in oklab, var(--color-bg-alt) 75%, white);
  }

  .hero-card p {
    max-width: none;
    margin-bottom: 0;
  }

  .place-grid,
  .forms-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    margin-top: 1.2rem;
  }

  .card {
    padding: 1.2rem;
  }

  .about-card {
    width: 100%;
    border-left: 6px solid var(--color-accent);
  }

  .about-card p:last-child {
    margin-bottom: 0;
  }

  .place-grid .card {
    border-left: 6px solid var(--color-primary);
  }

  .forms-grid .card {
    border-left: 6px solid var(--color-primary);
  }

  .place-image {
    margin: 1rem 0 0;
  }

  .place-image img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 0.65rem;
    border: 1px solid color-mix(in oklab, var(--color-primary) 18%, white);
    background: color-mix(in oklab, var(--color-bg-alt) 75%, white);
  }

  .gatherings {
    background: color-mix(in oklab, var(--color-bg-alt) 68%, white);
  }

  .iframe-card {
    padding: 1.2rem;
  }

  .gathering-details {
    margin-bottom: 1rem;
    border-left: 6px solid var(--color-accent);
  }

  .gathering-image {
    margin: 1rem 0 0;
  }

  .gathering-image img {
    display: block;
    width: min(100%, 560px);
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 0.65rem;
    border: 1px solid color-mix(in oklab, var(--color-primary) 18%, white);
    background: color-mix(in oklab, var(--color-bg-alt) 75%, white);
  }

  .calendar-embed {
    width: 100%;
    height: clamp(360px, 68vh, 760px);
    border: 1px solid color-mix(in oklab, var(--color-primary) 18%, white);
    border-radius: 0.6rem;
    background: var(--color-surface);
  }

  form {
    display: grid;
    gap: 0.55rem;
  }

  input,
  textarea {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in oklab, var(--color-primary) 24%, white);
    padding: 0.65rem 0.75rem;
    font: inherit;
    background: #fff;
  }

  input:focus,
  textarea:focus {
    outline: 2px solid color-mix(in oklab, var(--color-accent) 75%, white);
    outline-offset: 1px;
  }

  #form-status {
    min-height: 1.2em;
    margin: 0;
    font-size: 0.95rem;
  }

  #form-status[data-state='error'] {
    color: #8b2f2f;
  }

  #form-status[data-state='success'] {
    color: var(--color-primary);
  }

  .newsletter-row {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .newsletter-form {
    margin-top: 0.4rem;
  }

  .form-note {
    margin: 0 0 0.15rem;
    font-size: 0.95rem;
    color: color-mix(in oklab, var(--color-text) 72%, var(--color-primary));
  }

  .newsletter-button {
    margin-top: 0.35rem;
  }

  .site-footer {
    border-top: 1px solid color-mix(in oklab, var(--color-primary) 18%, white);
    background: color-mix(in oklab, var(--color-bg) 78%, white);
    padding: 1.3rem 0 1.6rem;
  }

  .footer-wrap {
    display: grid;
    gap: 0.3rem;
  }

  .footer-wrap p {
    margin: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .section {
      padding: 1.5rem 0;
    }

    .eyebrow {
      font-size: 1.1rem;
    }

    .nav-list {
      gap: 0.4rem;
    }

    .button {
      width: 100%;
    }

    .newsletter-button {
      width: 100%;
    }

    .calendar-embed {
      height: clamp(320px, 62vh, 620px);
    }
  }
</style>
