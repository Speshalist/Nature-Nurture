---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nature & Nurture: Southern Maryland',
  description = 'A Spirituality in Nature Group (SING) in Southern Maryland.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap');

  :root {
    --color-primary: #2d4a3e;
    --color-accent: #d4a373;
    --color-bg: #faedcd;
    --color-bg-alt: #fefae0;
    --color-text: #1c2521;
    --color-surface: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: var(--color-text);
    background: linear-gradient(180deg, var(--color-bg-alt), var(--color-bg));
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    line-height: 1.2;
    color: var(--color-primary);
    margin-top: 0;
  }

  p {
    margin-top: 0;
  }

  a {
    color: var(--color-primary);
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
  }

  .skip-link:focus {
    left: 1rem;
    top: 1rem;
    z-index: 10;
    background: var(--color-surface);
    padding: 0.5rem 0.75rem;
    border: 2px solid var(--color-primary);
    border-radius: 0.25rem;
  }

  .container {
    width: min(1100px, 92vw);
    margin-inline: auto;
  }

  .section {
    padding: 2rem 0;
  }

  .surface {
    background: color-mix(in oklab, var(--color-surface) 88%, var(--color-bg-alt));
    border: 1px solid color-mix(in oklab, var(--color-primary) 12%, white);
    border-radius: 0.9rem;
    box-shadow: 0 8px 18px rgba(28, 37, 33, 0.08);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 999px;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    padding: 0.65rem 1.1rem;
    background: var(--color-primary);
    color: #fff;
  }

  .button:hover,
  .button:focus-visible {
    background: color-mix(in oklab, var(--color-primary) 86%, black);
  }

  .button:disabled {
    opacity: 0.7;
    cursor: wait;
  }
</style>
